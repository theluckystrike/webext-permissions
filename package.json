{
  "name": "@theluckystrike/webext-permissions",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "1.0.0",
  "description": "Runtime permission checking and requesting for Chrome extensions. Part of @zovo/webext.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "permissions",
    "runtime-permissions",
    "typescript",
    "webextension",
    "browser-extension",
    "manifest-v3",
    "optional-permissions",
    "chrome-permissions"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-permissions.git"
  },
  "homepage": "https://zovo.one",
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
